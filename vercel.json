{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    },
    "api/auth/*.js": {
      "maxDuration": 15
    },
    "api/stats/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/stats/script.js", "destination": "/api/stats/script" },
    { "source": "/stats/send", "destination": "/api/stats/send" }
  ]
}
